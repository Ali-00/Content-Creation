{
  "name": "AI-LinkedIn-Content-Engine",

  "agents": [
    "ai_trend_researcher",
    "technical_content_strategist",
    "linkedin_content_creator",
    "personal_brand_editor"
  ],

  "tasks": [
    {
      "name": "research_ai_trends",

      "description": "Research the latest credible developments related to {subject} across AI Engineering, Data Science, Machine Learning, Generative AI, LLMs, RAG, agentic AI, AI automation, MLOps, data engineering, and production AI systems. Prioritize developments published within the last 7 days whenever suitable recent information is available. Focus on topics that are technically meaningful and relevant to AI Engineers, Data Scientists, ML Engineers, technical founders, engineering leaders, and recruiters hiring AI talent. Prioritize official company announcements, technical documentation, research papers, reputable engineering blogs, GitHub repositories, recognized AI publications, and credible practitioners. Perform no more than 5 focused search queries and read no more than 6 webpages in detail. Skip inaccessible, outdated, repetitive, promotional, or low-value sources. Do not retry failed URLs more than once. Never invent sources, URLs, statistics, product capabilities, benchmarks, research findings, or release details. Never use file:// URLs. Stop researching once sufficient evidence has been collected for one strong LinkedIn content angle.",

      "expected_output": "A concise, source-backed AI trend brief focused on one strong and timely content angle related to {subject}. Include: the key development, publication or announcement date, named companies or technologies involved, important technical details, why it matters to experienced AI and Data Science professionals, possible limitations or tradeoffs, practical implications, and 3 to 6 accessible source URLs. Clearly distinguish confirmed facts from interpretation. Exclude failed, inaccessible, duplicated, outdated, or unsupported sources.",

      "agent": "ai_trend_researcher"
    },

    {
      "name": "develop_technical_perspective",

      "description": "Analyze the AI trend research supplied through task context and develop a thoughtful professional perspective about {subject}. Explain what the development means in practice for AI Engineers, Data Scientists, ML Engineers, technical teams, startups, and organizations building production AI systems. Identify the real engineering implications, implementation challenges, tradeoffs, risks, misconceptions, and opportunities. Look beyond the headline and determine what an experienced practitioner should actually understand. Connect the topic naturally to relevant areas such as LLM applications, RAG, AI agents, evaluation, MLOps, deployment, data quality, system design, scalability, observability, latency, cost, reliability, governance, or human oversight when supported by the research. Use only the supplied research. Do not search the web, open URLs, access files, invent personal experiences, fabricate technical claims, or introduce unsupported numbers. Avoid generic observations such as 'AI is transforming industries.'",

      "expected_output": "A structured technical perspective containing: one clear central insight, why the topic matters now, 3 to 5 practical implications, important engineering tradeoffs or limitations, one credible professional opinion, one useful lesson readers can apply, and 2 to 3 possible LinkedIn post angles. The analysis must be technically credible, specific, practical, and fully supported by the supplied research.",

      "agent": "technical_content_strategist",

      "context": [
        "research_ai_trends"
      ]
    },

    {
      "name": "create_linkedin_content",

      "description": "Create publication-ready LinkedIn content about {subject} using only the supplied AI trend research and technical perspective. Write from the viewpoint of a Data Scientist and AI Engineer with approximately four years of hands-on experience building AI, data, machine-learning, LLM, RAG, automation, and production systems. The writing should sound like a real practitioner sharing a useful observation, lesson, technical opinion, or recent discovery. Do not claim a specific personal experience unless it is supported by the provided context. When personal framing is useful, use honest language such as 'One pattern I keep noticing,' 'What stands out to me,' or 'From an engineering perspective.' Never pretend that the writer personally tested a product, attended an event, led a project, or achieved a result unless that fact is supplied. Avoid journalistic summaries, corporate marketing language, exaggerated hype, motivational clichés, generic AI introductions, and phrases commonly associated with AI-generated writing. Use short, natural paragraphs and varied sentence lengths. Build the post around one clear idea rather than summarizing every research finding. Include concrete technical details, a thoughtful viewpoint, practical value, and a natural closing question that encourages professional discussion. Do not search the web, open files, invent sources, fabricate statistics, or introduce unsupported claims.",

      "expected_output": "Produce three clearly differentiated LinkedIn post options about {subject}: (1) Educational — teaches a practical technical lesson; (2) Opinion — presents a balanced and defensible professional perspective; and (3) Practitioner Insight — explains what the development means for people building real AI systems. Each option must include a strong non-clickbait opening, a clear central argument, specific technical substance, practical relevance, a natural discussion question, and 3 to 5 focused hashtags. Keep each post approximately 180 to 350 words. Also provide one concise visual or carousel concept for each option and one suggested first comment that adds value rather than repeating the post. Do not wrap the output in a Markdown code block.",

      "agent": "linkedin_content_creator",

      "context": [
        "research_ai_trends",
        "develop_technical_perspective"
      ]
    },

    {
      "name": "finalize_personal_brand_content",

      "description": "Review the LinkedIn post options supplied directly through task context and finalize them for an experienced Data Science and AI Engineering personal brand. Compare factual and technical claims against the supplied AI research and technical perspective. Remove unsupported claims, invented personal experiences, fake citations, exaggerated conclusions, generic statements, repetition, excessive emojis, clickbait, corporate jargon, unnecessary headings, and language that sounds machine-generated. Rewrite sentences that could appear in hundreds of generic AI posts. Preserve useful technical detail while keeping the writing natural and readable. The voice should be thoughtful, technically credible, professionally confident, curious, practical, and human. It should sound like an experienced practitioner sharing knowledge with peers, not a journalist, marketer, influencer, or AI assistant. Ensure the opening earns attention without exaggeration. Ensure every paragraph adds information or perspective. Do not search the web, open files, read Markdown documents, call tools, describe your editing process, or introduce new facts. Return only the final ready-to-post package.",

      "expected_output": "Return ONLY the final publication-ready LinkedIn content package. Do not use a Markdown code block. Do not include planning, reasoning, workflow commentary, editing notes, or instructions to the user. Present three finalized options labeled Educational, Opinion, and Practitioner Insight. For each option, include: the complete LinkedIn post, one visual or carousel concept, one useful first comment, and 3 to 5 relevant hashtags. The posts must be immediately ready to copy and publish without further editing. All factual claims must be supported by the supplied research, and the writing must sound natural, original, technically experienced, and human.",

      "agent": "personal_brand_editor",

      "context": [
        "research_ai_trends",
        "develop_technical_perspective",
        "create_linkedin_content"
      ]
    }
  ],

  "process": "sequential",
  "verbose": true,
  "memory": false,
  "inputs": {}
}